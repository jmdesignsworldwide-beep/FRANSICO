# ─────────────────────────────────────────────────────────────
# F&I WASH Auto Services — variables de entorno (plantilla)
# Copia este archivo a .env.local y rellena los valores.
# NUNCA subas .env.local al repositorio (ver .gitignore).
# ─────────────────────────────────────────────────────────────

# URL canónica del sitio en producción (usada para metadata/SEO/sitemap)
NEXT_PUBLIC_SITE_URL=https://fiwash.com.do

# ── Supabase (portal de fotos /admin) ────────────────────────
# Estas dos son PÚBLICAS (van al cliente) y funcionan con RLS:
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# La SERVICE ROLE es SECRETA: solo server-side, NUNCA con prefijo NEXT_PUBLIC,
# nunca en el cliente, nunca en el repo. (La app usa RLS con la sesión del admin;
# esta clave solo se necesita para scripts de mantenimiento, si acaso.)
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
